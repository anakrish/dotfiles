#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
set -euo pipefail

history_file="${XDG_STATE_HOME:-$HOME/.local/state}/niri-rice/clipboard.jsonl"

if [ ! -s "$history_file" ]; then
    notify-send "Clipboard history" "No clipboard history yet"
    exit 0
fi

selection="$(
    python3 - "$history_file" <<'PY' | fuzzel --dmenu --prompt="Clipboard: "
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
entries = []
for line in path.read_text(errors="replace").splitlines():
    try:
        entries.append(json.loads(line))
    except json.JSONDecodeError:
        pass

for index, entry in enumerate(reversed(entries), start=1):
    print(f"{index}\t{entry.get('preview', '')}")
PY
)"

[ -n "$selection" ] || exit 0
index="${selection%%	*}"

python3 - "$history_file" "$index" <<'PY' | wl-copy
import json
import pathlib
import sys

path = pathlib.Path(sys.argv[1])
selected = int(sys.argv[2])
entries = []
for line in path.read_text(errors="replace").splitlines():
    try:
        entries.append(json.loads(line))
    except json.JSONDecodeError:
        pass

entry = list(reversed(entries))[selected - 1]
print(entry.get("text", ""), end="")
PY

notify-send "Clipboard" "Copied selected history item"
