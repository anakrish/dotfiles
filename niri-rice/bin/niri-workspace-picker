#!/usr/bin/env bash
# SPDX-License-Identifier: MIT
set -euo pipefail

action="${1:-focus}"

case "$action" in
    focus|move-window|move-column) ;;
    *)
        echo "Usage: niri-workspace-picker [focus|move-window|move-column]" >&2
        exit 1
        ;;
esac

workspace_list="$(
    python3 -c '
import json
import subprocess

APP_ID = "rice-scratchpad"


def niri_json(*args):
    try:
        out = subprocess.run(
            ["niri", "msg", "-j", *args],
            capture_output=True, text=True, check=True,
        ).stdout
        return json.loads(out)
    except Exception:
        return None


workspaces = niri_json("workspaces")
if workspaces is None:
    raise SystemExit

# Skip the hidden scratchpad stash: a non-focused workspace whose only
# windows are the scratchpad terminal.
windows = niri_json("windows") or []
apps_by_ws = {}
for win in windows:
    apps_by_ws.setdefault(win.get("workspace_id"), []).append(win.get("app_id"))
stash_ws_ids = {
    ws_id for ws_id, apps in apps_by_ws.items()
    if apps and all(app == APP_ID for app in apps)
}

# Order: unnamed (numbered) workspaces first by index, then named ones.
def sort_key(item):
    return (1 if item.get("name") else 0, item.get("idx", 0))


for workspace in sorted(workspaces, key=sort_key):
    if workspace.get("id") in stash_ws_ids and not workspace.get("is_focused"):
        continue
    idx = workspace.get("idx", "")
    name = workspace.get("name") or str(idx)
    state = "focused" if workspace.get("is_focused") else "active" if workspace.get("active_window_id") is not None else "empty"
    print(f"{idx}: {name} [{state}]")
'
)"

selection="$(
    {
        printf '%s\n' "$workspace_list"
        printf '%s\n' "new: name current workspace"
    } | fuzzel --dmenu --prompt="Workspace: "
)"

[ -n "$selection" ] || exit 0

if [ "$selection" = "new: name current workspace" ]; then
    exec "$HOME/.local/bin/niri-rename-workspace"
fi

workspace="${selection#*: }"
workspace="${workspace% \[*}"
[ -n "$workspace" ] || exit 0

case "$action" in
    focus)
        niri msg action focus-workspace "$workspace"
        ;;
    move-window)
        niri msg action move-window-to-workspace "$workspace"
        ;;
    move-column)
        niri msg action move-column-to-workspace "$workspace"
        ;;
esac
