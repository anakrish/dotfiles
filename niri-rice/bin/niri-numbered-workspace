#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
"""Focus or target the Nth *numbered* workspace, skipping named ones.

niri's `focus-workspace N` uses the raw positional index, which counts named
workspaces (chat, web, ...) and the hidden scratchpad stash. This wrapper
instead maps N to the Nth unnamed, non-stash workspace on the focused output,
so the number keys line up with the numbered workspaces shown in waybar (and
never land on a named workspace).

Usage: niri-numbered-workspace <focus|move-column|move-window> <N>
"""

import json
import subprocess
import sys

APP_ID = "rice-scratchpad"

ACTIONS = {
    "focus": "focus-workspace",
    "move-column": "move-column-to-workspace",
    "move-window": "move-window-to-workspace",
}


def niri_json(*args):
    try:
        out = subprocess.run(
            ["niri", "msg", "-j", *args],
            capture_output=True, text=True, check=True,
        ).stdout
        return json.loads(out)
    except Exception:
        return None


def main():
    if len(sys.argv) != 3 or sys.argv[1] not in ACTIONS:
        print("Usage: niri-numbered-workspace <focus|move-column|move-window> <N>",
              file=sys.stderr)
        return 2
    action = ACTIONS[sys.argv[1]]
    try:
        n = int(sys.argv[2])
    except ValueError:
        print("N must be an integer", file=sys.stderr)
        return 2

    workspaces = niri_json("workspaces")
    if workspaces is None:
        return 1
    windows = niri_json("windows") or []

    apps_by_ws = {}
    for win in windows:
        apps_by_ws.setdefault(win.get("workspace_id"), []).append(win.get("app_id"))
    stash_ws_ids = {
        ws_id for ws_id, apps in apps_by_ws.items()
        if apps and all(app == APP_ID for app in apps)
    }

    focused_output = next(
        (w.get("output") for w in workspaces if w.get("is_focused")), None
    )

    numbered = sorted(
        (
            w for w in workspaces
            if w.get("output") == focused_output
            and not w.get("name")
            and w.get("id") not in stash_ws_ids
        ),
        key=lambda w: w.get("idx", 0),
    )
    if not numbered:
        return 0

    # Clamp: requesting beyond the last numbered workspace lands on the
    # trailing empty one (niri always keeps one), matching default behaviour.
    target = numbered[n - 1] if n <= len(numbered) else numbered[-1]

    subprocess.run(
        ["niri", "msg", "action", action, str(target.get("idx"))],
        capture_output=True, text=True, check=False,
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
