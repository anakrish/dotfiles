#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
"""Toggle a floating "scratchpad" terminal in niri.

Behaviour (a real show/hide toggle, no workspace jumping):
  * If the scratchpad window is on the *current* workspace -> hide it by
    moving it to the persistent "scratchpad" stash workspace (focus stays put).
  * If it exists elsewhere (the stash or another workspace) -> show it by
    moving it to the current workspace, floating it, and focusing it.
  * If it does not exist yet -> spawn it (Alacritty + a persistent tmux
    session) on the current workspace.

The stash workspace must be declared persistently in the niri config
(`workspace "scratchpad"`), otherwise `move-window-to-workspace "scratchpad"`
silently does nothing.
"""

import json
import os
import subprocess
import sys
import time

STASH_WS = "scratchpad"
APP_ID = "rice-scratchpad"
TITLE = "Scratchpad"

STATE_DIR = os.path.join(
    os.environ.get("XDG_STATE_HOME", os.path.expanduser("~/.local/state")),
    "niri-rice",
)
WINDOW_ID_FILE = os.path.join(STATE_DIR, "scratchpad-window-id")


def niri_json(*args):
    try:
        out = subprocess.run(
            ["niri", "msg", "-j", *args],
            capture_output=True,
            text=True,
            check=True,
        ).stdout
        return json.loads(out)
    except (subprocess.CalledProcessError, json.JSONDecodeError, FileNotFoundError):
        return None


def niri_action(*args):
    subprocess.run(
        ["niri", "msg", "action", *args],
        capture_output=True,
        text=True,
        check=False,
    )


def read_tracked_id():
    try:
        with open(WINDOW_ID_FILE) as fh:
            return fh.read().strip()
    except OSError:
        return ""


def write_tracked_id(window_id):
    os.makedirs(STATE_DIR, exist_ok=True)
    with open(WINDOW_ID_FILE, "w") as fh:
        fh.write(str(window_id) + "\n")


def clear_tracked_id():
    try:
        os.remove(WINDOW_ID_FILE)
    except OSError:
        pass


def current_workspace(workspaces):
    """Return the (idx, id) of the focused workspace."""
    for ws in workspaces:
        if ws.get("is_focused"):
            return ws.get("idx"), ws.get("id")
    # Fall back to the active workspace if none reports focus.
    for ws in workspaces:
        if ws.get("is_active"):
            return ws.get("idx"), ws.get("id")
    return None, None


def find_scratchpad(windows, tracked_id):
    """Locate the scratchpad window, preferring the tracked id."""
    if tracked_id:
        for win in windows:
            if str(win.get("id")) == str(tracked_id):
                return win
    for win in windows:
        if win.get("app_id") == APP_ID or win.get("title") == TITLE:
            return win
    return None


def show(window, current_idx):
    """Bring the scratchpad to the current workspace, floating and focused."""
    wid = str(window["id"])
    if current_idx is not None:
        niri_action(
            "move-window-to-workspace",
            str(current_idx),
            "--window-id",
            wid,
            "--focus",
            "false",
        )
    niri_action("move-window-to-floating", "--id", wid)
    niri_action("focus-window", "--id", wid)


def hide(window):
    """Stash the scratchpad on the hidden workspace; keep focus where it is."""
    wid = str(window["id"])
    niri_action(
        "move-window-to-workspace",
        STASH_WS,
        "--window-id",
        wid,
        "--focus",
        "false",
    )


def spawn():
    """Launch a new scratchpad terminal on the current workspace."""
    proc = subprocess.Popen(
        [
            "alacritty",
            "--class",
            APP_ID,
            "--title",
            TITLE,
            "--option",
            "window.dimensions.columns=110",
            "--option",
            "window.dimensions.lines=30",
            "--command",
            "tmux",
            "new-session",
            "-A",
            "-s",
            "scratchpad",
        ]
    )
    for _ in range(40):
        windows = niri_json("windows") or []
        for win in windows:
            if (
                win.get("pid") == proc.pid
                or win.get("app_id") == APP_ID
                or win.get("title") == TITLE
            ):
                write_tracked_id(win["id"])
                # The open-floating window-rule already floats it; make sure.
                niri_action("move-window-to-floating", "--id", str(win["id"]))
                niri_action("focus-window", "--id", str(win["id"]))
                return
        time.sleep(0.1)


def main():
    workspaces = niri_json("workspaces")
    windows = niri_json("windows")
    if workspaces is None or windows is None:
        print("niri is not reachable", file=sys.stderr)
        return 1

    current_idx, current_id = current_workspace(workspaces)
    window = find_scratchpad(windows, read_tracked_id())

    if window is not None:
        write_tracked_id(window["id"])
        on_current = current_id is not None and window.get("workspace_id") == current_id
        if on_current:
            hide(window)
        else:
            show(window, current_idx)
        return 0

    clear_tracked_id()
    spawn()
    return 0


if __name__ == "__main__":
    sys.exit(main())
