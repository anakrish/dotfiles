{
  "layer": "top",
  "position": "top",
  "spacing": 6,
  "margin-top": 0,
  "margin-left": 0,
  "margin-right": 0,
  "modules-left": [
    "custom/niri-workspaces",
    "wlr/taskbar"
  ],
  "modules-center": [
    "custom/niri-window"
  ],
  "modules-right": [
    "mpris",
    "idle_inhibitor",
    "pulseaudio",
    "network",
    "custom/system",
    "backlight",
    "battery",
    "clock",
    "tray"
  ],
  "custom/niri-workspaces": {
    "exec": "$HOME/.local/bin/waybar-niri-workspaces",
    "interval": 2,
    "return-type": "json",
    "format": "{}",
    "escape": false,
    "on-click": "niri msg action toggle-overview"
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "active-first": true,
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": [
      "waybar"
    ]
  },
  "custom/niri-window": {
    "exec": "$HOME/.local/bin/waybar-niri-window",
    "interval": 2,
    "return-type": "json",
    "format": "{}",
    "escape": true,
    "max-length": 80
  },
  "mpris": {
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} {dynamic}",
    "format-stopped": "",
    "dynamic-len": 36,
    "tooltip-format": "{player}: {title} - {artist}",
    "player-icons": {
      "default": "пАБ",
      "spotify": "пЖЉ",
      "firefox": "пЙ©",
      "chromium": "пЙ®"
    },
    "status-icons": {
      "playing": "пБЛ",
      "paused": "пБМ",
      "stopped": "пБН"
    },
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "пБЃ",
      "deactivated": "пБ∞"
    },
    "tooltip-format-activated": "Idle inhibit on",
    "tooltip-format-deactivated": "Idle inhibit off"
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon} пКФ",
    "format-muted": "muted пЪ©",
    "format-icons": {
      "headphone": "пА•",
      "headset": "пЦР",
      "default": [
        "пА¶",
        "пАІ",
        "пА®"
      ]
    },
    "scroll-step": 2,
    "on-click": "pavucontrol"
  },
  "network": {
    "format-wifi": "{signalStrength}% пЗЂ",
    "format-ethernet": "{ifname} пГБ",
    "format-disconnected": "offline вЪ†",
    "format-alt": "{essid} {signalStrength}% пЗЂ",
    "tooltip-format": "{essid}\n{ifname}: {ipaddr}/{cidr}\nvia {gwaddr}"
  },
  "custom/system": {
    "exec": "$HOME/.local/bin/waybar-system",
    "interval": 3,
    "return-type": "json",
    "format": "{}",
    "tooltip": true
  },
  "backlight": {
    "device": "amdgpu_bl1",
    "format": "{percent}% {icon}",
    "format-icons": [
      "оОН",
      "оПУ",
      "оПС",
      "оПП",
      "оПО",
      "оПН",
      "оПК",
      "оПИ",
      "оОЫ"
    ]
  },
  "battery": {
    "bat": "BAT0",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% пГІ",
    "format-plugged": "{capacity}% пЗ¶",
    "format-full": "full пЙА",
    "format-alt": "{time} {icon}",
    "format-icons": [
      "пЙД",
      "пЙГ",
      "пЙВ",
      "пЙБ",
      "пЙА"
    ]
  },
  "clock": {
    "format": "{:%a %b %d  %I:%M %p}",
    "format-alt": "{:%Y-%m-%d  %H:%M}",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 8
  }
}
